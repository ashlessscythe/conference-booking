generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MembershipRole {
  MEMBER
  ADMIN
  OWNER
}

enum BookingStatus {
  CONFIRMED
  CANCELLED
}

enum DeviceRotation {
  LANDSCAPE
  PORTRAIT
}

enum PlanTier {
  FREE
  PRO
}

enum PromoKind {
  FREE_MONTHS
  PERCENT_OFF
  AMOUNT_OFF
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  memberships   Membership[]
  bookings      Booking[]
  invitationsSent Invitation[] @relation("InvitationsSent")
  promoCodesCreated PromoCode[] @relation("PromoCodesCreated")
  promoRedemptions  PromoRedemption[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Organization {
  id                       String         @id @default(cuid())
  name                     String
  slug                     String         @unique
  planTier                 PlanTier       @default(FREE)
  stripeCustomerId         String?        @unique
  stripeSubscriptionId     String?        @unique
  stripeSubscriptionStatus String?
  stripePriceId            String?
  stripeCurrentPeriodEnd   DateTime?
  /// When set and in the future, org has promo-granted Pro access.
  promoExpiresAt           DateTime?
  /// Stripe promotion code id to attach on the next Checkout session.
  pendingStripePromotionCodeId String?
  members                  Membership[]
  rooms                    Room[]
  devices                  KioskDevice[]
  invitations              Invitation[]
  promoRedemptions         PromoRedemption[]
  settings                 SystemSettings?
  createdAt                DateTime       @default(now())
  updatedAt                DateTime       @updatedAt
}

model PromoCode {
  id                     String       @id @default(cuid())
  code                   String       @unique
  kind                   PromoKind
  active                 Boolean      @default(true)
  freeMonths             Int?
  percentOff             Int?
  amountOffCents         Int?
  durationMonths         Int?
  maxRedemptions         Int?
  redemptionCount        Int          @default(0)
  expiresAt              DateTime?
  note                   String?
  stripeCouponId         String?
  stripePromotionCodeId  String?      @unique
  createdByUserId        String
  createdBy              User         @relation("PromoCodesCreated", fields: [createdByUserId], references: [id], onDelete: Cascade)
  redemptions            PromoRedemption[]
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt

  @@index([active])
}

model PromoRedemption {
  id             String       @id @default(cuid())
  promoCodeId    String
  organizationId String
  redeemedById   String
  redeemedAt     DateTime     @default(now())
  promoCode      PromoCode    @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  redeemedBy     User         @relation(fields: [redeemedById], references: [id], onDelete: Cascade)

  @@unique([promoCodeId, organizationId])
  @@index([organizationId])
}

model Invitation {
  id             String         @id @default(cuid())
  organizationId String
  email          String
  role           MembershipRole @default(MEMBER)
  token          String         @unique @default(cuid())
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy      User           @relation("InvitationsSent", fields: [invitedById], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([email])
}

model Membership {
  id             String         @id @default(cuid())
  userId         String
  organizationId String
  role           MembershipRole @default(MEMBER)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime       @default(now())

  @@unique([userId, organizationId])
}

model Room {
  id             String        @id @default(cuid())
  organizationId String
  name           String
  slug           String
  capacity       Int           @default(4)
  floor          String?
  description    String?
  outOfService   Boolean       @default(false)
  qrVersion      Int           @default(1)
  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  bookings       Booking[]
  devices        KioskDevice[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@unique([organizationId, slug])
}

model Booking {
  id          String        @id @default(cuid())
  roomId      String
  organizerId String
  title       String
  startAt     DateTime
  endAt       DateTime
  status      BookingStatus @default(CONFIRMED)
  room        Room          @relation(fields: [roomId], references: [id], onDelete: Cascade)
  organizer   User          @relation(fields: [organizerId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([roomId, startAt, endAt])
  @@index([organizerId, startAt])
}

model KioskDevice {
  id             String         @id @default(cuid())
  organizationId String
  roomId         String?
  name           String
  deviceToken    String         @unique @default(cuid())
  pairingToken   String?        @unique
  enabled        Boolean        @default(true)
  rotation       DeviceRotation @default(LANDSCAPE)
  lastHeartbeat  DateTime?
  pairedAt       DateTime?
  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  room           Room?          @relation(fields: [roomId], references: [id], onDelete: SetNull)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model SystemSettings {
  id                   String       @id @default(cuid())
  organizationId       String       @unique
  cleaningBufferMin    Int          @default(10)
  startingSoonMin      Int          @default(15)
  heartbeatTimeoutMin  Int          @default(5)
  organization         Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  updatedAt            DateTime     @updatedAt
}
