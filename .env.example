# Environment template — copy to .env
# cp .env.example .env

# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://conference:conference@localhost:5432/conference_booking?schema=public"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Resend magic-link email (optional in dev — emails log to console if unset)
AUTH_RESEND_KEY=""
EMAIL_FROM="Conference Booking <onboarding@resend.dev>"

# Public app URL used for QR codes
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Stripe billing (optional in local/dev — without these, orgs stay on Free)
# Create a Product + recurring Price in Stripe Dashboard, then paste IDs:
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
# Webhook URL: {AUTH_URL}/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated,
#         customer.subscription.deleted, invoice.paid, invoice.payment_failed

# Platform owners who can create promo codes (comma-separated emails)
PLATFORM_OWNER_EMAILS="admin@example.com"

